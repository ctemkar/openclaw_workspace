<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.chetantemkar.trading-monitor</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/chetantemkar/.openclaw/workspace/app/trading_monitor.py</string>
        <string>--continuous</string>
    </array>
    
    <key>WorkingDirectory</key>
    <string>/Users/chetantemkar/.openclaw/workspace/app</string>
    
    <key>StandardOutPath</key>
    <string>/Users/chetantemkar/.openclaw/workspace/app/trading_monitor_service.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/chetantemkar/.openclaw/workspace/app/trading_monitor_service.error.log</string>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>KeepAlive</key>
    <true/>
    
    <key>StartInterval</key>
    <integer>300</integer>
    
    <key>ProcessType</key>
    <string>Background</string>
    
    <key>LowPriorityIO</key>
    <true/>
</dict>
</plist>